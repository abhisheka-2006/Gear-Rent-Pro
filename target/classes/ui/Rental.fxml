<?xml version="1.0" encoding="UTF-8"?>
 <?import javafx.scene.control.*?>
 <?import javafx.scene.layout.*?>
 <?import javafx.geometry.Insets?>
 
 <VBox xmlns:fx="http://javafx.com/fxml"
       fx:controller="com.gearrent.controller.RentalController"
       spacing="10" style="-fx-padding:20;">
   <Label text="Create Rental"
          style="-fx-font-size:18;-fx-font-weight:bold;"/>
   <GridPane hgap="10" vgap="10">
     <Label text="Branch:"     GridPane.rowIndex="0" GridPane.columnIndex="0"/>
     <ComboBox fx:id="branchBox"   GridPane.rowIndex="0"
               GridPane.columnIndex="1" prefWidth="250"/>
     <Label text="Equipment:"  GridPane.rowIndex="1" GridPane.columnIndex="0"/>
     <ComboBox fx:id="equipmentBox" GridPane.rowIndex="1"
               GridPane.columnIndex="1" prefWidth="250"/>
     <Label text="Customer:"   GridPane.rowIndex="2" GridPane.columnIndex="0"/>
     <ComboBox fx:id="customerBox"  GridPane.rowIndex="2"
               GridPane.columnIndex="1" prefWidth="250"/>
     <Label text="Start Date:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
     <DatePicker fx:id="startDatePicker" GridPane.rowIndex="3"
                 GridPane.columnIndex="1"/>
     <Label text="End Date:"   GridPane.rowIndex="4" GridPane.columnIndex="0"/>
     <DatePicker fx:id="endDatePicker"   GridPane.rowIndex="4"
                 GridPane.columnIndex="1"/>
     <Label text="Payment:"    GridPane.rowIndex="5" GridPane.columnIndex="0"/>
     <ComboBox fx:id="paymentStatusBox" GridPane.rowIndex="5"
               GridPane.columnIndex="1"/>
   </GridPane>
 
   <Separator/>
   <HBox spacing="20">
     <VBox spacing="4">
       <Label text="Rental Amount:"/>
       <Label fx:id="rentalAmountLabel" text="LKR 0.00"
              style="-fx-font-weight:bold;"/>
     </VBox>
     <VBox spacing="4">
       <Label text="Security Deposit:"/>
       <Label fx:id="depositLabel" text="LKR 0.00"
              style="-fx-font-weight:bold;"/>
     </VBox>
     <VBox spacing="4">
       <Label text="Final Payable:"/>
       <Label fx:id="finalPayableLabel" text="LKR 0.00"
              style="-fx-font-weight:bold;-fx-text-fill:#1F3864;"/>
     </VBox>
   </HBox>
   <Button text="Create Rental" onAction="#handleCreateRental"
           style="-fx-background-color:#2E75B6;-fx-text-fill:white;
                  -fx-font-weight:bold;-fx-padding:8 20;"/>
   <Label fx:id="errorLabel" text="" wrapText="true"/>
 </VBox>
